{
  "version": 2,
  "functions": {
    "api/index.ts": { "maxDuration": 10, "memory": 512 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/v/(.*)", "destination": "/api/index.ts" },
    { "source": "/admin(.*)", "destination": "/api/index.ts" },
    { "source": "/img/(.*)", "destination": "/api/index.ts" },
    { "source": "/", "destination": "/api/index.ts" }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  }
}
