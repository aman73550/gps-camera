{
  "expo": {
    "name": "Verified GPS Camera",
    "slug": "gps-camera",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gpscamera",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E8F0FE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gpscamera",
      "infoPlist": {
        "NSCameraUsageDescription": "Verified GPS Camera needs camera access to take geo-tagged photos.",
        "NSLocationWhenInUseUsageDescription": "Verified GPS Camera needs location access to tag photos with GPS coordinates."
      }
    },
    "android": {
      "package": "com.gpscamera",
      "adaptiveIcon": {
        "backgroundColor": "#E8F0FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Verified GPS Camera needs camera access to take geo-tagged photos.",
          "recordAudioPermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Verified GPS Camera needs location access to tag photos with GPS coordinates."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
